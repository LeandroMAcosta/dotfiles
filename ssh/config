Host github.com
  HostName github.com
  User git
  # Local key fetched from 1Password by install.sh; bypass the 1Password SSH
  # agent so commits/pushes never trigger a per-use approval prompt.
  IdentityFile ~/.ssh/id_ed25519_leacosta97
  IdentitiesOnly yes
  IdentityAgent none

Host ssh.dev.azure.com-mediapro
  HostName ssh.dev.azure.com
  User git
  IdentityFile ~/.ssh/mediapro_azure.pub
  IdentitiesOnly yes
  HostkeyAlgorithms +ssh-rsa
  PubkeyAcceptedAlgorithms +ssh-rsa

Host bitbucket.org
  HostName bitbucket.org
  User git
  # Local key fetched from 1Password by install.sh; bypass the 1Password SSH
  # agent so commits/pushes never trigger a per-use approval prompt.
  IdentityFile ~/.ssh/id_ed25519_engbim
  IdentitiesOnly yes
  IdentityAgent none

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
